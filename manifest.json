{
  "manifest_version": 3,
  "name": "OCW Tracker",
  "version": "1.0",
  "description": "Auto-tracks your MIT OpenCourseware visits and lets you jump back to your last page.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://ocw.mit.edu/*"],
      "js": ["content.js"]
    }
  ]
}
